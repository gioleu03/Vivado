library IEEE;
use IEEE.STD_LOGIC_1164.ALL;
use IEEE.NUMERIC_STD.ALL;

package switch_types is
    type ninebit_array is array (0 to 3) of std_logic_vector(8 downto 0);
    type eightbit_array is array (0 to 3) of std_logic_vector(7 downto 0);
    type sel_array is array (0 to 3) of std_logic_vector(3 downto 0);
    type occu_array is array (0 to 3) of std_logic_vector(4 downto 0);
    type input_sel is array (0 to 3) of integer range 0 to 3;
    type state_type is (IDLE, WAIT_DATA, SENDING);
    type state_array is array (0 to 3) of state_type;
    type ninebit_matrix is array (0 to 3, 0 to 3) of std_logic_vector(8 downto 0);
    type occu_matrix is array (0 to 3, 0 to 3) of std_logic_vector(4 downto 0);
    type matrix_en_type is array (0 to 3) of std_logic_vector(0 to 3);
end package;

library IEEE;
use IEEE.STD_LOGIC_1164.ALL;
use IEEE.NUMERIC_STD.ALL;
library work;
use work.switch_types.all;

entity crossbar_1 is
Port (
        clk      : in std_logic;
        reset    : in std_logic;
        data_in  : in ninebit_array;
        dst_port : in sel_array;
        data_out : out eightbit_array;
        tx_ctrl  : out std_logic_vector(0 to 3)  
     );
end crossbar_1;

architecture Behavioral of crossbar_1 is
    signal matrix_rd_en   : matrix_en_type := (others => (others => '0'));
    signal matrix_occu      : occu_matrix;
    signal fifo_matrix_out : ninebit_matrix;
    signal selected_input  : input_sel := (others => 0);
    signal state           : state_array := (others => IDLE);
    signal current_port    : input_sel := (others => 0);
    signal matrix_we       : matrix_en_type;

    component newfifo_1 is
        port (  
            reset          : in std_logic; 
            wclk           : in std_logic; 
            rclk           : in std_logic; 
            write_enable   : in std_logic; 
            read_enable    : in std_logic; 
            fifo_occu_in   : out std_logic_vector(4 downto 0); 
            fifo_occu_out  : out std_logic_vector(4 downto 0); 
            write_data_in  : in std_logic_vector(8 downto 0); 
            read_data_out  : out std_logic_vector(8 downto 0) 
        ); 
    end component;

begin
    -- Generazione Matrix di FIFO
    Gen_In: for i in 0 to 3 generate
        Gen_Out: for j in 0 to 3 generate
            -- FIXED: (i,j) -> (i)(j)
            matrix_we(i)(j) <= '1' when (dst_port(i)(j) = '1') else '0';
            
            buff_inst: newfifo_1    
                port map(  
                    reset          => reset,
                    wclk           => clk, 
                    rclk           => clk, 
                    write_enable   => matrix_we(i)(j),    -- FIXED indexing
                    read_enable    => matrix_rd_en(i)(j), -- FIXED indexing
                    write_data_in  => data_in(i),
                    read_data_out  => fifo_matrix_out(i, j),
                    fifo_occu_in   => open, 
                    fifo_occu_out  => matrix_occu(i, j)
                ); 
        end generate;
    end generate;

    -- Fair Queuing Manager
        process(clk, reset)
        begin
            if reset = '1' then
                state(0) <= IDLE;
                current_port(0) <= 0;
                tx_ctrl(0) <= '0';
                data_out(0) <= (others => '0');
                for i in 0 to 3 loop 
                   matrix_rd_en(i)(0) <= '0'; -- FIXED indexing
                end loop;
            elsif rising_edge(clk) then
                -- Default
                for i in 0 to 3 loop 
                    matrix_rd_en(i)(0) <= '0'; -- FIXED indexing
                end loop;
                tx_ctrl(0) <= '0';

                case state(0) is
                    when IDLE =>
                        if (dst_port(current_port(0))(0) = '1') then
                            selected_input(0) <= current_port(0);
			--matrix_rd_en(current_port(j))(j) <= '1'; -- FIXED indexing
                            state(0) <= WAIT_DATA;
                        else
                            matrix_rd_en(current_port(0))(0) <= '0'; -- FIXED indexing
                            current_port(0) <= (current_port(0) + 1) mod 4;
                        end if;

                    when WAIT_DATA =>
                        --matrix_rd_en(selected_input(j))(j) <= '1'; -- FIXED indexing
                        state(0) <= SENDING;
                        
                    when SENDING =>
                        data_out(0) <= fifo_matrix_out(selected_input(0), 0)(7 downto 0);
                        tx_ctrl(0) <= '1';
                        if fifo_matrix_out(selected_input(0), 0)(8) = '1' then -- EOF
                            state(0) <= IDLE;
                            current_port(0) <= (selected_input(0) + 1) mod 4;
                           matrix_rd_en(selected_input(0))(0) <= '0'; -- FIXED indexing
                        else
                           matrix_rd_en(selected_input(0))(0) <= '1'; -- FIXED indexing
                        end if;
                    when others =>
                        state(0) <= IDLE;
                end case;
            end if;
        end process;
	

process(clk, reset)
        begin
            if reset = '1' then
                state(1) <= IDLE;
                current_port(1) <= 0;
                tx_ctrl(1) <= '0';
                data_out(1) <= (others => '0');
                for i in 0 to 3 loop 
                   matrix_rd_en(i)(1) <= '0'; -- FIXED indexing
                end loop;
            elsif rising_edge(clk) then
                -- Default
                for i in 0 to 3 loop 
                    matrix_rd_en(i)(1) <= '0'; -- FIXED indexing
                end loop;
                tx_ctrl(1) <= '0';

                case state(1) is
                    when IDLE =>
                        if (dst_port(current_port(1))(1) = '1') then
                            selected_input(1) <= current_port(j);
			--matrix_rd_en(current_port(j))(j) <= '1'; -- FIXED indexing
                            state(1) <= WAIT_DATA;
                        else
                            matrix_rd_en(current_port(1))(1) <= '0'; -- FIXED indexing
                            current_port(1) <= (current_port(1) + 1) mod 4;
                        end if;

                    when WAIT_DATA =>
                        --matrix_rd_en(selected_input(j))(j) <= '1'; -- FIXED indexing
                        state(1) <= SENDING;
                        
                    when SENDING =>
                        data_out(1) <= fifo_matrix_out(selected_input(1), 1)(7 downto 0);
                        tx_ctrl(1) <= '1';
                        if fifo_matrix_out(selected_input(1), 1)(8) = '1' then -- EOF
                            state(1) <= IDLE;
                            current_port(1) <= (selected_input(1) + 1) mod 4;
                           matrix_rd_en(selected_input(1))(1) <= '0'; -- FIXED indexing
                        else
                           matrix_rd_en(selected_input(1))(1) <= '1'; -- FIXED indexing
                        end if;
                    when others =>
                        state(1) <= IDLE;
                end case;
            end if;
        end process;

process(clk, reset)
        begin
            if reset = '1' then
                state(2) <= IDLE;
                current_port(2) <= 0;
                tx_ctrl(2) <= '0';
                data_out(2) <= (others => '0');
                for i in 0 to 3 loop 
                   matrix_rd_en(i)(2) <= '0'; -- FIXED indexing
                end loop;
            elsif rising_edge(clk) then
                -- Default
                for i in 0 to 3 loop 
                    matrix_rd_en(i)(2) <= '0'; -- FIXED indexing
                end loop;
                tx_ctrl(2) <= '0';

                case state(2) is
                    when IDLE =>
                        if (dst_port(current_port(2))(2) = '1') then
                            selected_input(2) <= current_port(2);
			--matrix_rd_en(current_port(j))(j) <= '1'; -- FIXED indexing
                            state(2) <= WAIT_DATA;
                        else
                            matrix_rd_en(current_port(2))(2) <= '0'; -- FIXED indexing
                            current_port(2) <= (current_port(2) + 1) mod 4;
                        end if;

                    when WAIT_DATA =>
                        --matrix_rd_en(selected_input(j))(j) <= '1'; -- FIXED indexing
                        state(2) <= SENDING;
                        
                    when SENDING =>
                        data_out(2) <= fifo_matrix_out(selected_input(2), 2)(7 downto 0);
                        tx_ctrl(2) <= '1';
                        if fifo_matrix_out(selected_input(2), 2)(8) = '1' then -- EOF
                            state(2) <= IDLE;
                            current_port(2) <= (selected_input(2) + 1) mod 4;
                           matrix_rd_en(selected_input(2))(2) <= '0'; -- FIXED indexing
                        else
                           matrix_rd_en(selected_input(2))(2) <= '1'; -- FIXED indexing
                        end if;
                    when others =>
                        state(2) <= IDLE;
                end case;
            end if;
        end process;


process(clk, reset)
        begin
            if reset = '1' then
                state(3) <= IDLE;
                current_port(3) <= 0;
                tx_ctrl(3) <= '0';
                data_out(3) <= (others => '0');
                for i in 0 to 3 loop 
                   matrix_rd_en(i)(3) <= '0'; -- FIXED indexing
                end loop;
            elsif rising_edge(clk) then
                -- Default
                for i in 0 to 3 loop 
                    matrix_rd_en(i)(3) <= '0'; -- FIXED indexing
                end loop;
                tx_ctrl(3) <= '0';

                case state(3) is
                    when IDLE =>
                        if (dst_port(current_port(3))(3) = '1') then
                            selected_input(3) <= current_port(3);
			--matrix_rd_en(current_port(j))(j) <= '1'; -- FIXED indexing
                            state(3) <= WAIT_DATA;
                        else
                            matrix_rd_en(current_port(3))(3) <= '0'; -- FIXED indexing
                            current_port(3) <= (current_port(3) + 1) mod 4;
                        end if;

                    when WAIT_DATA =>
                        --matrix_rd_en(selected_input(j))(j) <= '1'; -- FIXED indexing
                        state(3) <= SENDING;
                        
                    when SENDING =>
                        data_out(3) <= fifo_matrix_out(selected_input(3), 3)(7 downto 0);
                        tx_ctrl(3) <= '1';
                        if fifo_matrix_out(selected_input(3), 3)(8) = '1' then -- EOF
                            state(3) <= IDLE;
                            current_port(3) <= (selected_input(3) + 1) mod 4;
                           matrix_rd_en(selected_input(3))(3) <= '0'; -- FIXED indexing
                        else
                           matrix_rd_en(selected_input(3))(3) <= '1'; -- FIXED indexing
                        end if;
                    when others =>
                        state(3) <= IDLE;
                end case;
            end if;
        end process;
end Behavioral;
